# Copy this file to .env.local (git-ignored) and fill in real values.
# Restart `next dev` after changing env vars.

# --- Supabase (stores registrations; read by the /admin panel) ---
# Project: zcyqqctqmxvxltnyynhz
# URL:     Supabase Dashboard → Project Settings → Data API → Project URL
SUPABASE_URL=https://zcyqqctqmxvxltnyynhz.supabase.co
# SERVICE ROLE key — Project Settings → API Keys → service_role.
# SECRET. Server-side only. Never expose to the browser or commit it.
SUPABASE_SERVICE_ROLE_KEY=

# --- Admin panel login (/admin) ---
# The password you type to view registrations.
ADMIN_PASSWORD=change-me-to-something-strong
# Random secret used to sign the login session cookie.
# Generate one:  openssl rand -base64 32
ADMIN_SESSION_SECRET=
